# Crear package.json en la raíz del proyecto
cat > package.json << 'EOF'
{
  "name": "webyapis",
  "version": "1.0.0",
  "description": "API REST para gestión de productos",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  }
}
EOF